#!/bin/bash
# Create VM: {{ name }} (VMID: {{ vmid }})
# Generated by DaVinci agent

qm create {{ vmid }} \
  --name {{ name }} \
  --memory {{ memory | default(2048) }} \
  --cores {{ cores | default(2) }} \
  --cpu host \
  --net0 virtio,bridge={{ bridge | default('vmbr0') }} \
  --scsihw virtio-scsi-single \
  --scsi0 {{ storage | default('local-lvm') }}:{{ disk_size | default('32G') }} \
  --ostype {{ ostype | default('l26') }} \
{% if iso is defined %}
  --ide2 {{ iso }},media=cdrom \
  --boot order=ide2\;scsi0
{% else %}
  --boot order=scsi0
{% endif %}

{% if start | default(false) %}
qm start {{ vmid }}
{% endif %}

echo "VM {{ vmid }} ({{ name }}) created on {{ node | default('auto') }}"
