# OpenWrt UCI firewall rule: {{ name }}
# Generated by DaVinci agent — apply with: ssh root@firewall 'sh /tmp/rule.sh'

uci add firewall rule
uci set firewall.@rule[-1].name='{{ name }}'
{% if src is defined %}
uci set firewall.@rule[-1].src='{{ src }}'
{% endif %}
{% if dest is defined %}
uci set firewall.@rule[-1].dest='{{ dest }}'
{% endif %}
{% if proto is defined %}
uci set firewall.@rule[-1].proto='{{ proto }}'
{% endif %}
{% if dest_port is defined %}
uci set firewall.@rule[-1].dest_port='{{ dest_port }}'
{% endif %}
{% if src_ip is defined %}
uci set firewall.@rule[-1].src_ip='{{ src_ip }}'
{% endif %}
{% if dest_ip is defined %}
uci set firewall.@rule[-1].dest_ip='{{ dest_ip }}'
{% endif %}
uci set firewall.@rule[-1].target='{{ target | default("ACCEPT") }}'
uci commit firewall
/etc/init.d/firewall reload
