# Docker Compose service: {{ name }}
# Generated by DaVinci agent
services:
  {{ name }}:
    image: {{ image }}
    container_name: {{ name }}
{% if ports is defined and ports %}
    ports:
{% for host_port, container_port in ports.items() %}
      - "{{ host_port }}:{{ container_port }}"
{% endfor %}
{% endif %}
{% if environment is defined and environment %}
    environment:
{% for key, value in environment.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% if volumes is defined and volumes %}
    volumes:
{% for vol in volumes %}
      - {{ vol }}
{% endfor %}
{% endif %}
    restart: {{ restart_policy | default('unless-stopped') }}
{% if network is defined %}
    networks:
      - {{ network }}

networks:
  {{ network }}:
    external: true
{% endif %}
