{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Intents Received",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "conductor_intents_total",
          "legendFormat": "Total Intents"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Tasks Dispatched by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "rate(conductor_tasks_total[5m])",
          "legendFormat": "{{ agent }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Active Tasks",
      "type": "bargauge",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "conductor_active_tasks",
          "legendFormat": "{{ agent }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "title": "Events Observed (Monitor)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(monitor_events_total[5m])",
          "legendFormat": "{{ event_type }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Task Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 10, "x": 10, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(monitor_task_duration_seconds_bucket[5m]))",
          "legendFormat": "{{ agent }} / {{ operation }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Anomalies Detected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "targets": [
        {
          "expr": "sum(monitor_anomalies_total)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Agent Health",
      "type": "table",
      "gridPos": { "h": 6, "w": 20, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "up{job=\"agent-health\"}",
          "legendFormat": "{{ agent }}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true },
            "renameByName": { "agent": "Agent", "Value": "Status", "instance": "Endpoint" }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
                ]
              }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["agent-swarm", "infrastructure"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Agent Swarm Overview",
  "uid": "agent-swarm-overview"
}
