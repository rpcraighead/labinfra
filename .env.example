# Agent Swarm Stack - Environment Configuration
# Copy to .env and fill in actual values
#
# Generate passwords:  openssl rand -base64 24
# Generate N8N key:    openssl rand -base64 32

# ==================== SHARED SERVICES ====================

RABBITMQ_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME

# ==================== CONDUCTOR ====================

# API key for Conductor REST API (leave blank to disable auth)
CONDUCTOR_API_KEY=CHANGE_ME

# ==================== LLM ====================

# Ollama endpoint — BigBrain (RTX 4070) at 10.0.8.55
OLLAMA_URL=http://10.0.8.55:11434
OLLAMA_MODEL=qwen3:8b-nothink

# ==================== PROXMOX (Superintendent) ====================

PROXMOX_ENDPOINT=10.0.8.100
PROXMOX_USERNAME=root@pam
PROXMOX_TOKEN_NAME=
PROXMOX_TOKEN_VALUE=
PROXMOX_PASSWORD=
PROXMOX_VERIFY_SSL=false

# ==================== OPENWRT FIREWALL (Sapper) ====================

# GL-MT6000 — reachable from DMZ at 10.0.8.1 or LAN at 10.0.50.1
FIREWALL_ENDPOINT=10.0.8.1
SAPPER_SSH_USER=root
SAPPER_SSH_KEY=./secrets/sapper_ssh_key

# ==================== DOCKER (Mercury) ====================

# Docker socket on the host, or remote TCP endpoint
MERCURY_DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_GID=112

# ==================== GIT REPOSITORIES (DaVinci) ====================

CODE_REPO_URL=
GIT_REPO_URL=

# ==================== EMAIL NOTIFICATIONS ====================

# SMTP server (camail01) — leave SMTP_HOST blank to disable all email
SMTP_HOST=
SMTP_PORT=587
NOTIFY_EMAIL=

# Per-agent SMTP credentials (if using separate mailboxes)
MERCURY_SMTP_USER=mercury@mail.rpc-cyberflight.com
MERCURY_SMTP_PASSWORD=
SUPERINTENDENT_SMTP_USER=superintendent@mail.rpc-cyberflight.com
SUPERINTENDENT_SMTP_PASSWORD=
SAPPER_SMTP_USER=sapper@mail.rpc-cyberflight.com
SAPPER_SMTP_PASSWORD=
DAVINCI_SMTP_USER=davinci@mail.rpc-cyberflight.com
DAVINCI_SMTP_PASSWORD=
MONITOR_SMTP_USER=monitor@mail.rpc-cyberflight.com
MONITOR_SMTP_PASSWORD=
SCRIBE_SMTP_USER=scribe@mail.rpc-cyberflight.com
SCRIBE_SMTP_PASSWORD=
JUDGE_SMTP_USER=judge@mail.rpc-cyberflight.com
JUDGE_SMTP_PASSWORD=

# ==================== MONITORING ====================

GRAFANA_PASSWORD=CHANGE_ME
ALERT_WEBHOOK_URL=

# ==================== LOGGING ====================

LOG_LEVEL=INFO
