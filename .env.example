# Agent Swarm Stack - Environment Configuration
# Copy to .env and fill in actual values
#
# Generate passwords:  openssl rand -base64 24
# Generate N8N key:    openssl rand -base64 32

# ==================== SHARED SERVICES ====================

RABBITMQ_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME

# ==================== EXTERNAL ENDPOINTS ====================

# Proxmox cluster
PROXMOX_ENDPOINT=<BIGHOST_IP>
PROXMOX_USERNAME=root@pam
PROXMOX_API_TOKEN=

# Firewall (OPNsense/pfSense)
FIREWALL_ENDPOINT=<FIREWALL_IP>

# ==================== GIT REPOSITORIES ====================

# Gitea on lab (update host:port to match your Gitea instance)
CODE_REPO_URL=http://<FILESERVER_IP>:3000/rpcraighead/iac
GIT_REPO_URL=http://<FILESERVER_IP>:3000/rpcraighead/lab-docs

# ==================== ALERTING ====================

# Webhook for Monitor alerts (Slack, Discord, ntfy, etc.)
ALERT_WEBHOOK_URL=

# ==================== API AUTHENTICATION ====================

# API key for Conductor REST API (leave blank to disable auth)
CONDUCTOR_API_KEY=CHANGE_ME

# ==================== LLM ====================

# Ollama endpoint for chat and observer LLM features
OLLAMA_URL=http://<BIGBRAIN_IP>:11434
OLLAMA_MODEL=qwen3:8b-nothink

# ==================== EMAIL NOTIFICATIONS ====================

# SMTP server for agent email notifications (leave SMTP_HOST blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# ==================== MONITORING ====================

GRAFANA_PASSWORD=CHANGE_ME

# ==================== LOGGING ====================

LOG_LEVEL=INFO
